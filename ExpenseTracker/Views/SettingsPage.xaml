<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Views.SettingsPage"
             Title="Cài đặt"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <StackLayout Padding="0" Spacing="0">

            <!-- User Profile Header -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   Margin="0,0,0,10"
                   CornerRadius="0"
                   HasShadow="True">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <!-- Avatar -->
                    <Frame Grid.Column="0"
                           Padding="0"
                           CornerRadius="40"
                           WidthRequest="80"
                           HeightRequest="80"
                           HasShadow="False"
                           BackgroundColor="#4ECDC4"
                           BorderColor="#4ECDC4"
                           IsClippedToBounds="True">
                        <Label x:Name="AvatarLabel"
                               Text="👤"
                               FontSize="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <!-- User Info -->
                    <StackLayout Grid.Column="1" 
                                 VerticalOptions="Center"
                                 Spacing="5">
                        <Label x:Name="UserNameLabel"
                               Text="User Name"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label x:Name="UserEmailLabel"
                               Text="user@example.com"
                               FontSize="14"
                               TextColor="#666666"/>
                    </StackLayout>

                    <!-- Edit Icon -->
                    <Label Grid.Column="2"
                           Text="✏️"
                           FontSize="24"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEditProfileTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- Account Section -->
            <Label Text="TÀI KHOẢN"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="#666666"
                   Margin="15,20,15,10"/>

            <Frame BackgroundColor="White" 
                   Padding="0" 
                   Margin="0,0,0,10"
                   CornerRadius="0"
                   HasShadow="False">
                <StackLayout Spacing="0">

                    <!-- Change Password -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="🔒"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Đổi mật khẩu"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="24"
                               TextColor="#CCCCCC"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangePasswordTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <BoxView HeightRequest="1" 
                             Color="#E0E0E0" 
                             Margin="15,0"/>

                    <!-- Language -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="🌐"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Ngôn ngữ"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label x:Name="LanguageValueLabel"
                               Grid.Column="2"
                               Text="Tiếng Việt"
                               FontSize="14"
                               TextColor="#666666"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <BoxView HeightRequest="1" 
                             Color="#E0E0E0" 
                             Margin="15,0"/>

                    <!-- Currency -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="💱"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Tiền tệ"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label x:Name="CurrencyValueLabel"
                               Grid.Column="2"
                               Text="VND"
                               FontSize="14"
                               TextColor="#666666"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCurrencyTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Data Section -->
            <Label Text="DỮ LIỆU"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="#666666"
                   Margin="15,20,15,10"/>

            <Frame BackgroundColor="White" 
                   Padding="0" 
                   Margin="0,0,0,10"
                   CornerRadius="0"
                   HasShadow="False">
                <StackLayout Spacing="0">

                    <!-- Export Data -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="📤"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Xuất dữ liệu"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="24"
                               TextColor="#CCCCCC"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExportDataTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <BoxView HeightRequest="1" 
                             Color="#E0E0E0" 
                             Margin="15,0"/>

                    <!-- Manage Categories -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="📁"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Quản lý danh mục"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="24"
                               TextColor="#CCCCCC"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnManageCategoriesTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- About Section -->
            <Label Text="VỀ ỨNG DỤNG"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="#666666"
                   Margin="15,20,15,10"/>

            <Frame BackgroundColor="White" 
                   Padding="0" 
                   Margin="0,0,0,10"
                   CornerRadius="0"
                   HasShadow="False">
                <StackLayout Spacing="0">

                    <!-- Version -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="ℹ️"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Phiên bản"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label Grid.Column="2"
                               Text="1.0.0"
                               FontSize="14"
                               TextColor="#666666"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                    </Grid>

                    <BoxView HeightRequest="1" 
                             Color="#E0E0E0" 
                             Margin="15,0"/>

                    <!-- About -->
                    <Grid Padding="15" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="📝"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Giới thiệu"
                               FontSize="16"
                               Margin="15,0,0,0"
                               VerticalOptions="Center"
                               TextColor="#333333"/>
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="24"
                               TextColor="#CCCCCC"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAboutTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Logout Button -->
            <Button Text="Đăng xuất"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="15"
                    Margin="15,30,15,10"
                    CornerRadius="10"/>

            <!-- Delete Account Button -->
            <Button Text="Xóa tài khoản"
                    Clicked="OnDeleteAccountTapped"
                    BackgroundColor="#FF4444"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="15"
                    Margin="15,0,15,30"
                    CornerRadius="10"/>

        </StackLayout>
    </ScrollView>

</ContentPage>