<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Views.TransactionDetailPage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*">
        <!-- 1. Header: Title + Delete Button -->
        <Frame Grid.Row="0" 
               Padding="15,10" 
               Margin="0" 
               BackgroundColor="White"
               CornerRadius="0"
               HasShadow="True">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="#333333"
                        FontSize="24"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center"/>

                <!-- Title -->
                <Label Grid.Column="1"
                       Text="Cập nhật giao dịch"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#333333"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <!-- Delete Button -->
                <Button Grid.Column="2"
                        x:Name="DeleteButton"
                        Text="🗑️"
                        Clicked="OnDeleteClicked"
                        BackgroundColor="Transparent"
                        TextColor="#FC5C65"
                        FontSize="24"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center"/>
            </Grid>
        </Frame>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10" Padding="10">
                <!-- 2. Wallet Selection - Ghim lên đầu, thu nhỏ, chính giữa -->
                <Frame Grid.Row="0"
                       Padding="10" 
                       Margin="60,10,60,0" 
                       BackgroundColor="White" 
                       CornerRadius="10"
                       HasShadow="True"
                       HorizontalOptions="Center">
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label x:Name="WalletNameLabel" 
                               Text="ATM" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="#333333"
                               HorizontalTextAlignment="Center"/>
                        <Label x:Name="WalletBalanceLabel" 
                               Text="0đ" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#26DE81"
                               HorizontalTextAlignment="Center"/>

                        <Picker x:Name="WalletPicker"
                                Title="Chọn ví"
                                SelectedIndexChanged="OnWalletChanged"
                                TextColor="#4ECDC4"
                                FontSize="12"
                                HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
                
                

                <!-- 3. Transaction Type Tabs -->
                <Frame Padding="5" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                        <Button x:Name="ExpenseTabButton" 
                                Grid.Column="0"
                                Text="Chi phí" 
                                Clicked="OnExpenseTabClicked"
                                BackgroundColor="#4ECDC4"
                                TextColor="White"
                                CornerRadius="8"
                                FontAttributes="Bold"/>

                        <Button x:Name="IncomeTabButton" 
                                Grid.Column="1"
                                Text="Thu nhập" 
                                Clicked="OnIncomeTabClicked"
                                BackgroundColor="#E0E0E0"
                                TextColor="#666666"
                                CornerRadius="8"
                                FontAttributes="Bold"/>

                        <!--<Button x:Name="TransferTabButton" 
                                Grid.Column="2"
                                Text="Chuyển tiền" 
                                Clicked="OnTransferTabClicked"
                                BackgroundColor="#E0E0E0"
                                TextColor="#666666"
                                CornerRadius="8"
                                FontAttributes="Bold"/>-->
                    </Grid>
                </Frame>

                <!-- 4. Date and Amount on Same Row -->
                <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                        <!-- Left: Date Selection -->
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Ngày giao dịch" FontSize="12" TextColor="#666666"/>
                            <DatePicker x:Name="TransactionDatePicker"
                                       Format="dd/MM/yyyy"
                                       TextColor="#333333"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Fill"/>
                        </VerticalStackLayout>

                        <!-- Right: Amount Entry -->
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Số tiền" FontSize="12" TextColor="#666666"/>
                            <Entry x:Name="AmountEntry" 
                                   Placeholder="0 VNĐ"
                                   Keyboard="Numeric"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#333333"
                                   PlaceholderColor="#CCCCCC"
                                   />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- 5. Categories -->
                <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Danh mục" FontSize="14" FontAttributes="Bold" TextColor="#333333"/>
                        <CollectionView x:Name="CategoriesCollectionView"
                                       SelectionMode="Single"
                                       SelectionChanged="OnCategorySelectionChanged">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="4" VerticalItemSpacing="10" HorizontalItemSpacing="10"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="8" 
                                           BackgroundColor="#F0F0F0" 
                                           CornerRadius="8"
                                           HasShadow="False"
                                           BorderColor="Transparent">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                <Setter Property="BorderColor" Value="#4ECDC4"/>
                                                <Setter Property="BackgroundColor" Value="#E0F7F5"/>
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                            <Label Text="{Binding Icon}" 
                                                   FontSize="24" 
                                                   HorizontalTextAlignment="Center"/>
                                            <Label Text="{Binding Name}" 
                                                   FontSize="9" 
                                                   HorizontalTextAlignment="Center"
                                                   TextColor="#333333"
                                                   LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- 6. Note Entry -->
                <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ghi chú" FontSize="12" TextColor="#666666"/>
                        <Entry x:Name="NoteEntry" 
                               Placeholder="Thêm ghi chú (tùy chọn)"
                               FontSize="14"
                               TextColor="#333333"
                               PlaceholderColor="#CCCCCC"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- 7. Exclude from Report 
                <Frame Padding="15" BackgroundColor="White" CornerRadius="10" HasShadow="True">
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="ExcludeFromReportCheckBox"
                                 Color="#4ECDC4"
                                 VerticalOptions="Center"/>
                        <Label Text="Loại khỏi báo cáo" 
                               FontSize="14" 
                               TextColor="#333333"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>-->

                <!-- 8. Action Buttons: Save and Cancel -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10">
                    <!-- Left: Save Button -->
                    <Button Grid.Column="0"
                            x:Name="SaveButton"
                            Text="Lưu"
                            Clicked="OnSaveClicked"
                            BackgroundColor="#4ECDC4"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="50"/>

                    <!-- Right: Cancel Button -->
                    <Button Grid.Column="1"
                            Text="Hủy"
                            Clicked="OnCancelClicked"
                            BackgroundColor="#E0E0E0"
                            TextColor="#666666"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="50"/>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>