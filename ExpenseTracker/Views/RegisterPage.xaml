<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ExpenseTracker.ViewModels"
             x:Class="ExpenseTracker.Views.RegisterPage"
             x:DataType="viewmodels:RegisterViewModel"
             Title="Đăng ký"
             BackgroundColor="#F8F8F8"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <StackLayout Padding="30" Spacing="20">

            <!-- Header -->
            <StackLayout Spacing="10" Margin="0,40,0,30">
                <Label Text="Chào người dùng mới!"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#333333"/>
                <Label Text="Chào mừng bạn đến với ứng dụng quản lý chi tiêu ExpenseTracker"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="#888888"
                       HorizontalTextAlignment="Center"/>
            </StackLayout>

            <!-- Error Message -->
            <Frame BackgroundColor="#FFEBEE" 
                   Padding="15" 
                   CornerRadius="10" 
                   HasShadow="False"
                   IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}" 
                       FontSize="14"
                       TextColor="#C62828"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <!-- Full Name Input -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <Entry Text="{Binding FullName}"
                       Placeholder="Họ Tên"
                       FontSize="16"
                       TextColor="#333333"
                       PlaceholderColor="#AAAAAA"
                       IsEnabled="{Binding IsNotLoading}"/>
            </Frame>

            <!-- Email Input -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <Entry Text="{Binding Email}"
                       Placeholder="Email"
                       Keyboard="Email"
                       FontSize="16"
                       TextColor="#333333"
                       PlaceholderColor="#AAAAAA"
                       IsEnabled="{Binding IsNotLoading}"/>
            </Frame>

            <!-- Gender Selection -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Frame Grid.Column="0"
                       BackgroundColor="{Binding MaleFrameBackgroundColor}"
                       Padding="0"
                       CornerRadius="15"
                       HasShadow="False">
                    <StackLayout Spacing="10" Padding="20">
                        <Label Text="Nam"
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#333333"/>
                        <Label Text="👨"
                               FontSize="60"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectGenderCommand}" 
                                            CommandParameter="Nam"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Column="1"
                       BackgroundColor="{Binding FemaleFrameBackgroundColor}"
                       Padding="0"
                       CornerRadius="15"
                       HasShadow="False">
                    <StackLayout Spacing="10" Padding="20">
                        <Label Text="Nữ"
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#333333"/>
                        <Label Text="👩"
                               FontSize="60"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectGenderCommand}" 
                                            CommandParameter="Nữ"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </Grid>

            <!-- Date of Birth -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <DatePicker Grid.Column="0"
                                Date="{Binding DateOfBirth}"
                                Format="dd/MM/yyyy"
                                TextColor="#333333"
                                FontSize="16"
                                HorizontalOptions="FillAndExpand"
                                IsEnabled="{Binding IsNotLoading}"/>
                    <Label Grid.Column="1"
                           Text="📅"
                           FontSize="24"
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>

            <!-- Password Input -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding Password}"
                           Placeholder="Mật Khẩu"
                           IsPassword="{Binding IsPasswordHidden}"
                           FontSize="16"
                           TextColor="#333333"
                           PlaceholderColor="#AAAAAA"
                           IsEnabled="{Binding IsNotLoading}"/>
                    <Label Grid.Column="1"
                           Text="{Binding PasswordVisibilityIcon}"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="#888888">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- Confirm Password Input -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding ConfirmPassword}"
                           Placeholder="Xác nhận mật khẩu"
                           IsPassword="{Binding IsConfirmPasswordHidden}"
                           FontSize="16"
                           TextColor="#333333"
                           PlaceholderColor="#AAAAAA"
                           IsEnabled="{Binding IsNotLoading}"/>
                    <Label Grid.Column="1"
                           Text="{Binding ConfirmPasswordVisibilityIcon}"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="#888888">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- Register Button -->
            <Button Text="{Binding RegisterButtonText}"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#4267B2"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    Padding="15"
                    CornerRadius="15"
                    Margin="0,10,0,0"
                    IsEnabled="{Binding IsNotLoading}"/>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                              IsVisible="{Binding IsLoading}"
                              Color="#4267B2"
                              HorizontalOptions="Center"
                              Margin="0,10,0,0"/>

            <!-- Login Link -->
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="5">
                <Label Text="Đã có tài khoản?"
                       FontSize="14"
                       TextColor="#888888"
                       VerticalOptions="Center"/>
                <Label Text="Đăng nhập ngay"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#4A90E2"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>