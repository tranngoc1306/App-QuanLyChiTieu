<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Views.ChangePasswordPage"
             Title="Đổi mật khẩu"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- Header Icon -->
            <Label Text="🔒"
                   FontSize="80"
                   HorizontalOptions="Center"
                   Margin="0,40,0,20"/>

            <Label Text="Đổi mật khẩu"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#333333"
                   Margin="0,0,0,10"/>

            <Label Text="Vui lòng nhập mật khẩu hiện tại và mật khẩu mới"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666666"
                   Margin="0,0,0,30"/>

            <!-- Current Password -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="10"
                   HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry x:Name="CurrentPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Mật khẩu hiện tại"
                           IsPassword="True"
                           FontSize="16"
                           TextColor="#333333"/>
                    <Label x:Name="CurrentPasswordIcon"
                           Grid.Column="1"
                           Text="🔒"
                           FontSize="20"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleCurrentPasswordVisibility"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- New Password -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="10"
                   HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry x:Name="NewPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Mật khẩu mới"
                           IsPassword="True"
                           FontSize="16"
                           TextColor="#333333"/>
                    <Label x:Name="NewPasswordIcon"
                           Grid.Column="1"
                           Text="🔒"
                           FontSize="20"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleNewPasswordVisibility"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- Confirm New Password -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="10"
                   HasShadow="False">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry x:Name="ConfirmPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Xác nhận mật khẩu mới"
                           IsPassword="True"
                           FontSize="16"
                           TextColor="#333333"/>
                    <Label x:Name="ConfirmPasswordIcon"
                           Grid.Column="1"
                           Text="🔒"
                           FontSize="20"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleConfirmPasswordVisibility"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <!-- Password Requirements -->
            <Frame BackgroundColor="#E8F5E9" 
                   Padding="15" 
                   CornerRadius="10"
                   HasShadow="False"
                   BorderColor="#4CAF50">
                <StackLayout Spacing="5">
                    <Label Text="Yêu cầu mật khẩu:"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#2E7D32"/>
                    <Label Text="• Tối thiểu 6 ký tự"
                           FontSize="12"
                           TextColor="#2E7D32"/>
                    <Label Text="• Nên chứa chữ hoa, chữ thường và số"
                           FontSize="12"
                           TextColor="#2E7D32"/>
                </StackLayout>
            </Frame>

            <!-- Change Password Button -->
            <Button x:Name="ChangePasswordButton"
                    Text="Đổi mật khẩu"
                    Clicked="OnChangePasswordClicked"
                    BackgroundColor="#4ECDC4"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="15"
                    Margin="0,20,0,0"
                    CornerRadius="10"/>

            <!-- Cancel Button -->
            <Button Text="Hủy"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#E0E0E0"
                    TextColor="#666666"
                    FontSize="16"
                    Padding="15"
                    CornerRadius="10"/>

        </StackLayout>
    </ScrollView>

</ContentPage>