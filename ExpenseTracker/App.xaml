<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ExpenseTracker"
             x:Class="ExpenseTracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <!--
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BoolToEyeIconConverter x:Key="BoolToEyeIconConverter"/>
            <converters:BoolToGenderColorConverter x:Key="BoolToGenderColorConverter"/>
            <converters:CountToBoolConverter x:Key="CountToBoolConverter"/>
            <converters:BalanceToColorConverter x:Key="BalanceToColorConverter"/>
            <converters:BalanceColorConverter x:Key="BalanceColorConverter"/>
            <converters:TodayBackgroundConverter x:Key="TodayBackgroundConverter"/>
            <converters:TodayFontAttributesConverter x:Key="TodayFontAttributesConverter"/>
            <converters:CurrentMonthTextColorConverter x:Key="CurrentMonthTextColorConverter"/>
            <converters:AmountColorConverter x:Key="AmountColorConverter"/>
            -->

            

            <!-- Color Definitions -->
            <Color x:Key="Primary">#FF7675</Color>
            <Color x:Key="Secondary">#4ECDC4</Color>
            <Color x:Key="Accent">#4A90E2</Color>
            <Color x:Key="Background">#F8F8F8</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="Error">#C62828</Color>
            <Color x:Key="TextPrimary">#333333</Color>
            <Color x:Key="TextSecondary">#888888</Color>

            <!-- Styles -->
            <Style TargetType="Frame" x:Key="InputFrameStyle">
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="HasShadow" Value="False"/>
            </Style>

            <Style TargetType="Entry" x:Key="InputEntryStyle">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="PlaceholderColor" Value="#AAAAAA"/>
            </Style>

            <Style TargetType="Button" x:Key="PrimaryButtonStyle">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="CornerRadius" Value="15"/>
            </Style>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
